# Google OAuth Desktop App credentials
# Buat di: https://console.cloud.google.com/apis/credentials
# 1. Enable "Google Drive API"
# 2. Create Credentials -> OAuth client ID:
#    - LOKAL: Application type: Desktop app
#    - HOSTING/VPS: Application type: Web application, dengan Authorized redirect URI:
#      https://domainmu.com/oauth2callback
# 3. Salin Client ID & Client Secret ke sini, lalu rename file ini jadi .env

GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# Password untuk masuk web console. Default 12345678 kalau dikosongkan.
DRIVE_ROUTER_PASSWORD=12345678

# Port web console (opsional, default 3020)
# PORT=3020

# Alamat publik web console (untuk redirect OAuth saat di-hosting).
# Kosongkan kalau jalan lokal (default http://localhost:3020).
# Contoh VPS: BASE_URL=https://drive.domainmu.com
# BASE_URL=
